# Copy to .env in this folder and set your key:
#   cp .env.example .env

OPENAI_API_KEY=your_openai_api_key_here

# Default model (assignment uses gpt-5.4-mini). Override if your account uses another name:
# OPENAI_MODEL=gpt-4o-mini

# Optional: for reasoning models that return blank replies (e.g. math), try:
# OPENAI_REASONING_EFFORT=low
